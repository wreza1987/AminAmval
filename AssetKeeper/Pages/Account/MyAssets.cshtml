@page
@using AssetKeeper.Shared
@model AssetKeeper.Pages.Account.MyAssetsModel
@{
    ViewData["Title"] = "اموال من";
}

<h3 class="mb-4">📦 اموال من</h3>

@if (!Model.Assignments.Any())
{
    <div class="alert alert-info">در حال حاضر هیچ اموالی تحویل شما نیست.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>کد اموال</th>
                <th>نام</th>
                <th>تاریخ تحویل</th>
                <th>تحویل‌دهنده</th>
                <th>توضیحات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Assignments)
            {
                <tr>
                    <td>@item.Asset.AssetCode</td>
                    <td>@item.Asset.Name</td>
                    <td>@item.AssignmentDate.ToPersian()</td>
                    <td>@item.DeliveredBy</td>
                    <td>@item.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}