@page
@model AssetKeeper.Pages.Account.MyAssetHistoryModel
@{
    ViewData["Title"] = "گردش اموال من";
}

<h3 class="mb-4">📋 گردش اموال من</h3>

@if (!Model.Assignments.Any())
{
    <div class="alert alert-info">هیچ سابقه‌ای یافت نشد.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>کد اموال</th>
                <th>نام</th>
                <th>تاریخ تحویل</th>
                <th>تاریخ بازگشت</th>
                <th>وضعیت</th>
                <th>توضیحات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Assignments)
            {
                <tr>
                    <td>@item.Asset.AssetCode</td>
                    <td>@item.Asset.Name</td>
                    <td>@item.AssignmentDate.ToString("yyyy/MM/dd")</td>
                    <td>@(item.ReturnDate?.ToString("yyyy/MM/dd") ?? "—")</td>
                    <td>
                        @if (item.ReturnDate == null)
                        {
                            <span class="badge bg-success">در اختیار شما</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">مسترد شده</span>
                        }
                    </td>
                    <td>@item.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}