@page
@model AssetKeeper.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "تغییر رمز عبور";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>تغییر رمز عبور</h2>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label>رمز عبور فعلی</label>
                    <input asp-for="Input.OldPassword" type="password" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label>رمز عبور جدید</label>
                    <input asp-for="Input.NewPassword" type="password" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label>تکرار رمز عبور جدید</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" required />
                </div>

                <button type="submit" class="btn btn-primary">تغییر رمز</button>
            </form>
        </div>
    </div>
</div>