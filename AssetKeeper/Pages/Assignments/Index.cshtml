@page
@using AssetKeeper.Shared
@model AssetKeeper.Pages.Assignments.IndexModel
@{
    ViewData["Title"] = "تخصیص‌های جاری";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>تخصیص‌های جاری اموال</h1>
        <a asp-page="Create" class="btn btn-success">+ تخصیص جدید</a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>کد اموال</th>
                <th>نام اموال</th>
                <th>پرسنل</th>
                <th>تاریخ تخصیص</th>
                <th>توضیحات</th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Assignments)
            {
                <tr>
                    <td>@item.Asset?.AssetCode</td>
                    <td>@item.Asset?.Name</td>
                    <td>@item.Employee?.FirstName @item.Employee?.LastName</td>
                    <td>@item.AssignmentDate.ToPersian()</td>
                    <td>@item.Notes</td>
                    <td>
                        <a asp-page="Return" asp-route-id="@item.Id" class="@ThemeColors.Buttons.WarningSm">عودت</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Assignments.Any())
    {
        <div class="alert alert-info">هیچ تخصیص جاری وجود ندارد.</div>
    }
</div>