@page
@model AssetKeeper.Pages.Assets.StatusModel
@using AssetKeeper.Domain.Enums
@using AssetKeeper.Shared
@{
    ViewData["Title"] = "تغییر وضعیت اموال";
}

<div class="container mt-4">
    <h2>تغییر وضعیت اموال</h2>
    <hr />

    <div class="row">
        <!-- ستون راست: اطلاعات کالا -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-body">
                    <h5>@Model.Asset.AssetCode - @Model.Asset.Name</h5>
                    <hr />
                    <p><strong>وضعیت فعلی:</strong> @Model.Asset.Status</p>
                </div>
            </div>
        </div>

        <!-- ستون چپ: فرم تغییر وضعیت -->
        <div class="col-md-7">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }

            @if (!ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>⚠️ @error.ErrorMessage</div>
                    }
                </div>
            }


            <form method="post">
                <input type="hidden" asp-for="Asset.Id" />

                <div class="mb-3">
                    <label class="form-label">وضعیت جدید <span class="text-danger">*</span></label>
                    <select asp-for="Asset.Status" class="form-select" id="StatusSelect">
                        <option value="InStock">@EnumHelper.GetDisplayName(AssetStatus.InStock)</option>
                        <option value="Assigned">@EnumHelper.GetDisplayName(AssetStatus.Assigned)</option>
                        <option value="UnderRepair">@EnumHelper.GetDisplayName(AssetStatus.UnderRepair)</option>
                        <option value="Scrapped">@EnumHelper.GetDisplayName(AssetStatus.Scrapped)</option>
                        <option value="Lost">@EnumHelper.GetDisplayName(AssetStatus.Lost)</option>
                        <option value="Sell">@EnumHelper.GetDisplayName(AssetStatus.Sell)</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label">توضیحات تغییر وضعیت</label>
                    <textarea asp-for="NewNote" class="form-control" rows="4" placeholder="دلیل تغییر وضعیت را بنویسید..."></textarea>
                </div>

                <!-- بخش تحویل فوری - فقط وقتی Assigned انتخاب شود -->
                <div id="ReassignSection" style="display: none;">
                    <h6 class="mt-4">تحویل فوری به پرسنل جدید</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">پرسنل جدید <span class="text-danger">*</span></label>
                            <input type="text" id="searchEmployee" class="form-control" placeholder="کد پرسنلی یا نام را تایپ کنید..." />
                            <select id="EmployeeSelect" class="form-select mt-2" style="display:none;"></select>
                            <input type="hidden" asp-for="NewEmployeeId" id="NewEmployeeId" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">تاریخ تحویل</label>
                            <input asp-for="NewAssignmentDate" type="date" class="form-control" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3">
                    <button type="submit" class="@ThemeColors.Buttons.Success">ثبت</button>
                    <a asp-page="Index" class="@ThemeColors.Buttons.Secondary">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('StatusSelect').addEventListener('change', function () {
        const reassignSection = document.getElementById('ReassignSection');
        reassignSection.style.display = (this.value === 'Assigned') ? 'block' : 'none';
    });

    // جستجوی آنلاین پرسنل
    let searchTimeout;
    document.getElementById('searchEmployee').addEventListener('input', function () {
        clearTimeout(searchTimeout);
        const term = this.value.trim();
        
        if (term.length < 2) {
            document.getElementById('EmployeeSelect').style.display = 'none';
            return;
        }

        searchTimeout = setTimeout(async () => {
            const response = await fetch('/Assets/Status?handler=SearchEmployees&term=' + encodeURIComponent(term));
            const data = await response.json();

            const select = document.getElementById('EmployeeSelect');
            select.innerHTML = '<option value="">انتخاب کنید...</option>';
            
            data.forEach(item => {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.text;
                select.appendChild(option);
            });

            select.style.display = 'block';
        }, 300);
    });

    document.getElementById('EmployeeSelect').addEventListener('change', function () {
        document.getElementById('NewEmployeeId').value = this.value;
    });
</script>