@page
@using AssetKeeper.Shared
@model AssetKeeper.Pages.Assets.CreateModel
@{
    ViewData["Title"] = "ثبت اموال جدید";
}

<div class="container mt-4">
    <h2>ثبت اموال جدید</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="post" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">کد اموال <span class="text-danger">*</span></label>
                <input asp-for="Asset.AssetCode" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">نام اموال <span class="text-danger">*</span></label>
                <input asp-for="Asset.Name" class="form-control" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">دسته‌بندی <span class="text-danger">*</span></label>
                <input type="text" id="searchCategory" class="form-control" placeholder="نام دسته‌بندی را تایپ کنید..." />
                <select id="CategorySelect" class="form-select mt-2" style="display:none;"></select>
                <input type="hidden" asp-for="Asset.CategoryId" id="CategoryId" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">برند <span class="text-danger">*</span></label>
                <input type="text" id="searchBrand" class="form-control" placeholder="نام برند را تایپ کنید..." />
                <select id="BrandSelect" class="form-select mt-2" style="display:none;"></select>
                <input type="hidden" asp-for="Asset.BrandId" id="BrandId" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">شماره سریال</label>
                <input asp-for="Asset.SerialNumber" class="form-control" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">مالک</label>
                <select asp-for="Asset.Owner" class="form-select">
                    <option value="Navaco">ناواکو</option>
                    <option value="MaskanBank">مسکن بانک</option>
                    <option value="Other">سایر</option>
                    <option value="Unknown">نامشخص</option>
                </select>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">تصویر کالا</label>
            <input type="file" asp-for="Asset.ImageFile" class="form-control" accept="image/*" />
        </div>

        <div class="mb-3">
            <label class="form-label">توضیحات</label>
            <textarea asp-for="Asset.Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="@ThemeColors.Custom.Button(40, 167, 69)">ثبت اموال جدید</button>
            <a asp-page="Index" class="@ThemeColors.Custom.Button(108, 117, 125, textColor: "white")">انصراف</a>
        </div>
    </form>
</div>

<script>
    // جستجوی دسته‌بندی
    let categoryTimeout;
    document.getElementById('searchCategory').addEventListener('input', function () {
        clearTimeout(categoryTimeout);
        const term = this.value.trim();

        if (term.length < 2) {
            document.getElementById('CategorySelect').style.display = 'none';
            return;
        }

        categoryTimeout = setTimeout(async () => {
            const response = await fetch(`/Assets/Create?handler=SearchCategories&term=${encodeURIComponent(term)}`);
            const data = await response.json();

            const select = document.getElementById('CategorySelect');
            select.innerHTML = '<option value="">انتخاب کنید...</option>';

            data.forEach(item => {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.text;
                select.appendChild(option);
            });

            select.style.display = 'block';
        }, 250);
    });

    document.getElementById('CategorySelect').addEventListener('change', function () {
        document.getElementById('CategoryId').value = this.value;
    });

    // جستجوی برند
    let brandTimeout;
    document.getElementById('searchBrand').addEventListener('input', function () {
        clearTimeout(brandTimeout);
        const term = this.value.trim();

        if (term.length < 2) {
            document.getElementById('BrandSelect').style.display = 'none';
            return;
        }

        brandTimeout = setTimeout(async () => {
            const response = await fetch(`/Assets/Create?handler=SearchBrands&term=${encodeURIComponent(term)}`);
            const data = await response.json();

            const select = document.getElementById('BrandSelect');
            select.innerHTML = '<option value="">انتخاب کنید...</option>';

            data.forEach(item => {
                const option = document.createElement('option');
                option.value = item.id;
                option.textContent = item.text;
                select.appendChild(option);
            });

            select.style.display = 'block';
        }, 250);
    });

    document.getElementById('BrandSelect').addEventListener('change', function () {
        document.getElementById('BrandId').value = this.value;
    });
</script>
