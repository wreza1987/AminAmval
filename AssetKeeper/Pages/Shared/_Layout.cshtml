<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - امین اموال</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand" href="/">امین اموال</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">داشبورد</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Assets/Index">اموال</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Categories/Index">دسته‌بندی‌ها</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Brands/Index">برندها</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Employees/Index">پرسنل</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Assignments/Index">تخصیص‌ها</a>
                        </li>
                        <!-- <li class="nav-item">
                            <a class="nav-link" asp-page="/Assignments/Create">تخصیص جدید</a>
                        </li> -->
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container mt-4">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted py-3 mt-5">
        <div class="container">
            <span>&copy; ۱۴۰۵ - سیستم مدیریت اموال (امین اموال)</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
