@using Microsoft.AspNetCore.Identity
@using AssetKeeper.Domain.Entities

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-light" asp-page="/Account/Manage/Index">
                👤 @User.Identity?.Name
            </a>
        </li>
        <li class="nav-item">
            <form method="post" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")">
                <button type="submit" class="nav-link btn btn-link text-light">خروج</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <!-- ✅ asp-area="" یعنی از Area خارج بشه -->
            <a class="nav-link text-light" asp-area="" asp-page="/Account/Login">ورود به سیستم</a>
        </li>
    }
</ul>