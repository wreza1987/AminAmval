@page
@model IndexModel
@{
    ViewData["Title"] = "داشبورد - امین اموال";
}

<div class="container mt-4">
    <h1 class="mb-4">داشبورد مدیریت اموال</h1>

    <div class="row">
        <div class="col-md-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5>تعداد کل اموال</h5>
                    <h2>@Model.TotalAssets</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5>اموال تخصیص یافته</h5>
                    <h2>@Model.AssignedAssets</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5>تعداد پرسنل</h5>
                    <h2>@Model.TotalEmployees</h2>
                </div>
            </div>
        </div>
    </div>
</div>