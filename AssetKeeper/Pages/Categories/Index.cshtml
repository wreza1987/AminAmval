@page
@model AssetKeeper.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "دسته‌بندی‌ها";
}

<div class="container mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>دسته‌بندی‌های اموال</h1>
        <a asp-page="Create" class="btn btn-success">+ دسته‌بندی جدید</a>
    </div>

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>نام دسته‌بندی</th>
                <th>توضیحات</th>
                <th>تعداد اموال</th>
                <th>عملیات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categories)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Description</td>
                    <td>@item.Assets.Count</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@item.Id" class="@ThemeColors.Buttons.WarningSm">ویرایش</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>