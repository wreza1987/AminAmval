@page
@model AssetKeeper.Pages.Employees.DetailsModel
@{
    ViewData["Title"] = "جزئیات پرسنل";
}

<div class="container mt-4">
    <h2>جزئیات پرسنل</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-body">
            <h4>@Model.Employee.FirstName @Model.Employee.LastName</h4>
            <p><strong>کد پرسنلی:</strong> @Model.Employee.PersonnelCode</p>
            <p><strong>کد ملی:</strong> @Model.Employee.NationalCode</p>
            <p><strong>واحد:</strong> @Model.Employee.Department</p>
            <p><strong>معاونت:</strong> @Model.Employee.VicePresidency</p>

        </div>
    </div>

    <h5>تاریخچه تغییرات پرسنل</h5>
    <div class="card">
        <div class="card-body" style="white-space: pre-wrap;">
            @if (string.IsNullOrEmpty(Model.Employee.Description))
            {
                <p class="text-muted">هنوز هیچ تغییری ثبت نشده است.</p>
            }
            else
            {
                @Model.Employee.Description
            }
        </div>
    </div>

    <a asp-page="Index" class="btn btn-secondary mt-3">بازگشت به لیست پرسنل</a>
</div>