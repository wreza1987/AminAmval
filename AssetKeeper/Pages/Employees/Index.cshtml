@page
@using AssetKeeper.Domain.Enums
@using AssetKeeper.Shared
@model AssetKeeper.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "لیست پرسنل";
}
<div class="container-fluid mt-3">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>مدیریت پرسنل <small class="text-muted fs-6">(@Model.TotalCount نفر)</small></h1>
        <div class="d-flex gap-2">
            <a asp-page="Create" class="btn btn-success">+ پرسنل جدید</a>
            <form method="post" asp-page-handler="Import" enctype="multipart/form-data" class="d-inline">
                <div class="input-group">
                    <input type="file" name="ExcelFile" class="form-control" accept=".xlsx" />
                    <button type="submit" class="btn btn-primary">آپلود اکسل</button>
                </div>
            </form>
            <a href="/Data/Seed/Employees.xlsx" class="btn btn-secondary" download>📥 فایل نمونه</a>
        </div>
    </div>

    <!-- فیلترها -->
    <form method="get">
        <div class="row g-2 align-items-end mb-3">

            <!-- کد پرسنلی -->
            <div class="col-auto">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <label class="form-label small fw-bold mb-0">کد پرسنلی</label>
                    <small class="text-muted">(یک فیلد = شامل، دو فیلد = بین)</small>
                </div>

                <div class="input-group input-group-sm">
                    <input name="FilterCodeFrom" value="@Model.FilterCodeFrom"
                        class="form-control" style="width:90px" placeholder="از..." />
                    <span class="input-group-text">تا</span>
                    <input name="FilterCodeTo" value="@Model.FilterCodeTo"
                        class="form-control" style="width:90px" placeholder="تا..." />
                </div>
                
            </div>

            <!-- نام -->
            <div class="col-auto">
                <label class="form-label small fw-bold mb-1">نام / نام خانوادگی</label>
                <input name="FilterName" value="@Model.FilterName"
                    class="form-control form-control-sm" style="width:150px" placeholder="شامل..." />
            </div>

            <!-- کد ملی -->
            <div class="col-auto">
                <label class="form-label small fw-bold mb-1">کد ملی</label>
                <input name="FilterNationalCode" value="@Model.FilterNationalCode"
                    class="form-control form-control-sm" style="width:130px" placeholder="شامل..." />
            </div>

            <!-- واحد dropdown -->
            <div class="col-auto">
                <label class="form-label small fw-bold mb-1">واحد / دپارتمان</label>
                <div class="dropdown">
                    <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside">
                        @(Model.FilterDepartments.Any() ? $"{Model.FilterDepartments.Count} انتخاب شده" : "همه")
                    </button>
                    <ul class="dropdown-menu p-2" style="min-width:180px;max-height:250px;overflow-y:auto">
                        <li>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="deptAll"
                                    onchange="toggleAll('dept-cb', this)"
                                    @(!Model.FilterDepartments.Any() ? "checked" : "") />
                                <label class="form-check-label" for="deptAll">همه</label>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        @foreach (var dept in Model.AllDepartments)
                        {
                            <li>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input dept-cb"
                                        name="FilterDepartments" value="@dept" id="d_@dept"
                                        @(Model.FilterDepartments.Contains(dept) ? "checked" : "")
                                        onchange="syncAll('dept-cb','deptAll')" />
                                    <label class="form-check-label" for="d_@dept">@dept</label>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- سطح دسترسی dropdown -->
            <div class="col-auto">
                <label class="form-label small fw-bold mb-1">سطح دسترسی</label>
                <div class="dropdown">
                    <button type="button" class="btn btn-outline-secondary btn-sm dropdown-toggle"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside">
                        @(Model.FilterAccessLevels.Any() ? $"{Model.FilterAccessLevels.Count} انتخاب شده" : "همه")
                    </button>
                    <ul class="dropdown-menu p-2" style="min-width:160px">
                        <li>
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="levelAll"
                                    onchange="toggleAll('level-cb', this)"
                                    @(!Model.FilterAccessLevels.Any() ? "checked" : "") />
                                <label class="form-check-label" for="levelAll">همه</label>
                            </div>
                        </li>
                        <li><hr class="dropdown-divider my-1" /></li>
                        @foreach (var lvl in Enum.GetValues<EmployeeAccessLevel>())
                        {
                            <li>
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input level-cb"
                                        name="FilterAccessLevels" value="@lvl" id="lv_@lvl"
                                        @(Model.FilterAccessLevels.Contains(lvl.ToString()) ? "checked" : "")
                                        onchange="syncAll('level-cb','levelAll')" />
                                    <label class="form-check-label" for="lv_@lvl">@EnumHelper.GetDisplayName(lvl)</label>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">🔍 فیلتر</button>
                <a asp-page="Index" class="btn btn-outline-secondary btn-sm">✖ پاک</a>
            </div>
        </div>
    </form>

    <!-- جدول -->
    @if (!Model.HasSearched)
    {
        <div class="alert alert-info mt-3">
            🔍 برای مشاهده پرسنل، فیلتر مورد نظر را اعمال کنید.
        </div>
    }
    else if (!Model.Employees.Any())
    {
        <div class="alert alert-warning mt-3">هیچ موردی یافت نشد.</div>
    }
    else
    {
        <table class="table table-striped table-hover table-sm">
            <thead class="table-dark">
                <tr>
                    <th>کد پرسنلی</th>
                    <th>نام و نام خانوادگی</th>
                    <th>کد ملی</th>
                    <th>واحد</th>
                    <th>سطح دسترسی</th>
                    <th>عملیات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Employees)
                {
                    <tr>
                        <td>@item.PersonnelCode</td>
                        <td>@item.FirstName @item.LastName</td>
                        <td>@item.NationalCode</td>
                        <td>@item.Department</td>
                        <td>
                            <span class="badge bg-@(
                                item.AccessLevel == EmployeeAccessLevel.Admin ? "danger"
                                : item.AccessLevel == EmployeeAccessLevel.WarehouseKeeper ? "warning"
                                : item.AccessLevel == EmployeeAccessLevel.Normal ? "success"
                                : "secondary")">
                                @EnumHelper.GetDisplayName(item.AccessLevel)
                            </span>
                        </td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@item.Id" class="@ThemeColors.Buttons.WarningSm">ویرایش</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-page="Index"
                           asp-route-Page="@i"
                           asp-route-FilterCode="@Model.FilterCodeFrom"
                           asp-route-FilterName="@Model.FilterName">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

@section Scripts {
<script>
function toggleRange(prefix, val) {
    document.getElementById(prefix + '_contains').style.display = val === 'contains' ? '' : 'none';
    document.getElementById(prefix + '_between').style.display = val === 'between' ? '' : 'none';
}
function toggleAll(cls, cb) {
    document.querySelectorAll('.' + cls).forEach(c => c.checked = cb.checked);
}
</script>

<script>
function toggleAll(cls, cb) {
    document.querySelectorAll('.' + cls).forEach(c => c.checked = cb.checked);
}
function syncAll(cls, allId) {
    const all = document.querySelectorAll('.' + cls);
    document.getElementById(allId).checked = [...all].every(c => c.checked);
}
</script>
}