@page
@using AssetKeeper.Shared
@model AssetKeeper.Pages.Employees.EditModel
@{
    ViewData["Title"] = "ویرایش پرسنل";
}

<div class="container mt-4">
    <h2>ویرایش اطلاعات پرسنل</h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger">
            <strong>لطفاً خطاها را اصلاح کنید:</strong>
            @Html.ValidationSummary(true)
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="Employee.Id" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">کد پرسنلی <span class="text-danger">*</span></label>
                <input asp-for="Employee.PersonnelCode" class="form-control" required />
                <span asp-validation-for="Employee.PersonnelCode" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">کد ملی <span class="text-danger">*</span></label>
                <input asp-for="Employee.NationalCode" class="form-control" required />
                <span asp-validation-for="Employee.NationalCode" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">نام <span class="text-danger">*</span></label>
                <input asp-for="Employee.FirstName" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">نام خانوادگی <span class="text-danger">*</span></label>
                <input asp-for="Employee.LastName" class="form-control" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">واحد / دپارتمان <span class="text-danger">*</span></label>
                <input asp-for="Employee.Department" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">تاریخ شروع به کار</label>
                <input asp-for="Employee.StartDate" type="date" class="form-control" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">سطح دسترسی</label>
            <select asp-for="Employee.AccessLevel" class="form-select">
                <option value="Normal">@EnumHelper.GetDisplayName(EmployeeAccessLevel.Normal)</option>
                <option value="WarehouseKeeper">@EnumHelper.GetDisplayName(EmployeeAccessLevel.WarehouseKeeper)</option>
                <option value="Admin">@EnumHelper.GetDisplayName(EmployeeAccessLevel.Admin)</option>
                <option value="Disable">@EnumHelper.GetDisplayName(EmployeeAccessLevel.Disable)</option>
            </select>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Employee.IsActive" type="checkbox" class="form-check-input" />
            <label asp-for="Employee.IsActive" class="form-check-label">فعال</label>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="@ThemeColors.Buttons.Primary">ذخیره تغییرات</button>
            <a asp-page="Index" class="btn btn-secondary">انصراف</a>
        </div>
    </form>
</div>