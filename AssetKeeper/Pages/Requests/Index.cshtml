@page
@model AssetKeeper.Pages.Requests.IndexModel
@{
    ViewData["Title"] = "درخواست‌های کاربران";
}

<h3 class="mb-4">📋 درخواست‌های کاربران</h3>

@{
    var grouped = Model.Requests
        .GroupBy(r => r.EmployeeId)
        .ToList();
}

@foreach (var group in grouped)
{
    var emp = group.First().Employee;
    var unread = group.Count(r => !r.IsRead &&
        r.Employee.AccessLevel == AssetKeeper.Domain.Enums.EmployeeAccessLevel.Normal);

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between">
            <span>
                👤 @emp.FirstName @emp.LastName
                <small class="text-muted me-2">(@emp.PersonnelCode)</small>
                @if (unread > 0)
                {
                    <span class="badge bg-danger">@unread پیام جدید</span>
                }
            </span>
            <button class="btn btn-sm btn-outline-secondary"
                    type="button" data-bs-toggle="collapse"
                    data-bs-target="#chat-@emp.Id">
                مشاهده / پاسخ
            </button>
        </div>
        <div class="collapse" id="chat-@emp.Id">
            <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                @foreach (var req in group.OrderBy(r => r.CreatedAt))
                {
                    // <!-- if (req.Employee.AccessLevel == AssetKeeper.Domain.Enums.EmployeeAccessLevel.Normal) -->
                    if (req.SenderEmployeeId == req.EmployeeId)
                    {
                        <div class="d-flex justify-content-start mb-2">
                            <div class="bg-light border rounded p-2 px-3" style="max-width: 75%;">
                                <div>@req.Message</div>
                                <div class="small text-muted mt-1">@req.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex justify-content-end mb-2">
                            <div class="bg-primary text-white rounded p-2 px-3" style="max-width: 75%;">
                                <div class="small opacity-75 mb-1">@req.SenderEmployee?.FirstName @req.SenderEmployee?.LastName</div>
                                <div>@req.Message</div>
                                <div class="small opacity-75 mt-1">@req.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
                            </div>
                        </div>
                    }
                }
            </div>
            <div class="card-footer">
                <form method="post" asp-page-handler="Reply">
                    <input type="hidden" name="ReplyEmployeeId" value="@emp.Id" />
                    <div class="input-group">
                        <input name="ReplyMessage" class="form-control"
                               placeholder="پاسخ خود را بنویسید..." />
                        <button type="submit" class="btn btn-primary">ارسال</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}